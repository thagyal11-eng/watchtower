{
    "name": "watchtower/watchtower",
    "description": "Production-safe, driver-agnostic dashboard for Laravel crons, queues and errors — that also lets you fix them.",
    "keywords": [
        "laravel",
        "queue",
        "horizon",
        "telescope",
        "scheduler",
        "monitoring",
        "exceptions",
        "dashboard"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "nesbot/carbon": "^2.0|^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Watchtower\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Watchtower\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\": "workbench/database/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Watchtower\\WatchtowerServiceProvider"
            ],
            "aliases": {
                "Watchtower": "Watchtower\\Watchtower"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
